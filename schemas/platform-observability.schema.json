{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/platform-observability/platform-observability.schema.json",
  "title": "Platform Observability Intent",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "platform", "signals"],
  "properties": {
    "apiVersion": { "const": "observability.platform/v1alpha1" },
    "kind": { "const": "PlatformObservability" },
    "metadata": {
      "type": "object",
      "required": ["name"],
      "properties": { "name": { "type": "string" } }
    },
    "platform": {
      "type": "object",
      "required": ["topology", "enforcement"],
      "properties": {
        "topology": { "type": "array", "items": { "type": "string" } },
        "enforcement": { "type": "array", "items": { "type": "string" } },
        "metadataCoverage": {
          "type": "object",
          "required": ["required", "purpose"],
          "properties": {
            "required": { "type": "array", "items": { "type": "string" } },
            "purpose": { "type": "string" }
          }
        },
        "signalLayers": { "type": "array", "items": { "type": "string" } }
      }
    },
    "signals": {
      "type": "array",
      "items": { "type": "string" }
    },
    "telemetryPipeline": {
      "type": "object",
      "properties": {
        "requiredSignals": { "type": "array", "items": { "type": "string" } }
      }
    },
    "alertContext": {
      "type": "object",
      "properties": {
        "contract": { "type": "string" },
        "required": { "type": "array", "items": { "type": "string" } }
      }
    },
    "decisionDashboards": {
      "type": "object",
      "properties": {
        "requiredQuestions": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
